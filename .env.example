# ─── File di esempio: copialo come .env e compila i valori reali ─────────────
# Su Render NON serve creare .env: configuri tutto via Environment Variables
# nella dashboard.

# Chiave segreta per le sessioni Flask (genera una stringa lunga e casuale)
SECRET_KEY=cambia-questa-stringa-con-qualcosa-di-lungo-e-casuale

# Database
# Sviluppo locale (default):
DATABASE_URL=sqlite:///invoice_manager.db
# Produzione su Render con disco persistente:
# DATABASE_URL=sqlite:////var/data/invoice_manager.db

# Nome azienda di default (poi sovrascrivibile per ogni utente)
COMPANY_NAME=La Tua Azienda Srl

# Resend (opzionale, alternativa a SMTP per migliore deliverability email).
# Configurazione VIA UI: vai su Impostazioni admin → "Provider email" →
# seleziona Resend, incolla API key (re_…) ed email mittente verificata.
# Su resend.com: crea account → verifica un dominio → genera API key.

# Crittografia at-rest dei secret (opzionale ma consigliato in produzione).
# Genera UNA TANTUM una master key Fernet e copiala qui sotto. Da quel momento
# tutti i secret salvati in DB (smtp_password, anthropic_api_key, oauth tokens,
# whatsapp_apikey, ecc.) vengono cifrati automaticamente.
# Per generare la key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANTE: se perdi questa chiave, NON puoi più decifrare i secret esistenti!
# SECRETS_ENCRYPTION_KEY=la-tua-chiave-fernet-base64-32byte

# Sentry (opzionale): error tracking. Se vuota, Sentry non si attiva.
# Trovi il DSN in https://sentry.io → Settings → Projects → [tuo progetto] → Client Keys
# SENTRY_DSN=https://xxxxxxxx@xxxxxx.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1   # 10% delle richieste tracciate (default 0.1)
