# ─── File di esempio: copialo come .env e compila i valori reali ─────────────
# Su Render NON serve creare .env: configuri tutto via Environment Variables
# nella dashboard.

# Chiave segreta per le sessioni Flask (genera una stringa lunga e casuale)
SECRET_KEY=cambia-questa-stringa-con-qualcosa-di-lungo-e-casuale

# Database
# Sviluppo locale (default):
DATABASE_URL=sqlite:///invoice_manager.db
# Produzione su Render con disco persistente:
# DATABASE_URL=sqlite:////var/data/invoice_manager.db

# Nome azienda di default (poi sovrascrivibile per ogni utente)
COMPANY_NAME=La Tua Azienda Srl
